# Backend (Go)

# PostgreSQL connection string.
# Example (local):
# DATABASE_URL=postgresql://user:password@localhost:5432/longride?sslmode=disable
# Example (hosted, usually needs sslmode=require):
# DATABASE_URL=postgresql://user:password@db.example.com:5432/longride?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/longride?sslmode=disable

# JWT secrets (use long random strings; keep access/refresh different).
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Server
PORT=8080
ENVIRONMENT=development

# CORS (only used when calling backend directly from a browser; if you proxy via Next /api, CORS is not involved)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW=60

# AI (Groq OpenAI-compatible endpoint)
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_API_KEY=your-groq-api-key-here

# Model name (must be supported by your AI provider)
AI_MODEL=openai/gpt-oss-120b